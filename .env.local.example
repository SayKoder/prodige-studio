# ─── Base de données ──────────────────────────────────────────────────────────
# Développement local (correspond à docker-compose.dev.yml)
DATABASE_URL="postgresql://prodige:devpassword@localhost:5432/prodige_dev"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET="REMPLACER_PAR_UN_SECRET_ALEATOIRE"
NEXTAUTH_URL="http://localhost:3000"

# ─── Admin (optionnel — utilisé par prisma/seed.ts) ──────────────────────────
# Si non défini : admin@prodige-studio.me / Prodige@Studio24!
# ADMIN_EMAIL="admin@prodige-studio.me"
# ADMIN_PASSWORD="VotreMotDePasseSecurisé"
